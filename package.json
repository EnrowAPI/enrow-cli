{
  "name": "@enrow/cli",
  "version": "1.0.0",
  "description": "Official CLI for the Enrow API — find and verify professional emails and phone numbers from your terminal",
  "bin": {
    "enrow": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --target node18",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "enrow",
    "cli",
    "email-finder",
    "email-verifier",
    "phone-finder"
  ],
  "author": "Enrow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/enrow/enrow-cli"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "enrow": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
